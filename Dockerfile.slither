FROM python:3.11-slim

WORKDIR /app

RUN apt-get update && apt-get install -y \
    git \
    curl \
    && rm -rf /var/lib/apt/lists/*

RUN pip install slither-analyzer --quiet

COPY slither_detectors/ ./slither_detectors/
COPY slither.config.json .
COPY setup.py .

RUN pip install -e . --quiet

ENTRYPOINT ["slither"]
CMD ["--help"]